  "dynamics": {
    "tick_seconds": 30,
    "rules": [
      {
        "name": "bp_result_available",
        "when": "flags.bp_ordered and (not flags.bp_checked) and t >= 30",
        "effects": {
          "set_flags": {
            "bp_checked": true
          }
        }
      },
      {
        "name": "ongoing_exposure_worsens_fast",
        "when": "flags.infusion_running and t >= 30",
        "effects": {
          "set_flags": {
            "shock_risk_increasing": true
          },
          "delta_symptoms": {
            "rash": 1,
            "wheeze": 1
          },
          "delta_vitals": {
            "SpO2": -4,
            "HR": 10,
            "SBP": -10,
            "DBP": -4,
            "RR": 2
          }
        }
      },
      {
        "name": "slow_mediator_cascade_before_epi_node",
        "when": "flags.stopped_infusion and (not flags.epi_im_given) and (not flags.epinephrine_delay_after_core_steps) and t >= 30 and t <= 330 and (t % 60 == 0)",
        "effects": {
          "delta_symptoms": {
            "wheeze": 1
          },
          "delta_vitals": {
            "SpO2": -1,
            "HR": 3,
            "SBP": -2,
            "DBP": -1,
            "RR": 1
          }
        }
      },
      {
        "name": "slow_airway_worsening_without_oxygen_before_epi_node",
        "when": "(not flags.epi_im_given) and (not flags.epinephrine_delay_after_core_steps) and (not flags.oxygen_on) and t >= 60 and (t % 60 == 0)",
        "effects": {
          "delta_vitals": {
            "SpO2": -1,
            "RR": 1
          }
        }
      },
      {
        "name": "severe_deterioration_after_epi_node_delay",
        "when": "(not flags.epi_im_given) and flags.epinephrine_delay_after_core_steps and t >= 30",
        "effects": {
          "set_flags": {
            "severe_deterioration_triggered": true,
            "adrenaline_delay_event": true,
            "shock_risk_increasing": true
          },
          "delta_vitals": {
            "SpO2": -4,
            "HR": 10,
            "SBP": -10,
            "DBP": -5,
            "RR": 3
          },
          "delta_symptoms": {
            "wheeze": 1,
            "consciousness": 1
          }
        }
      },
      {
        "name": "airway_compromise_after_epi_delay",
        "when": "(not flags.epi_im_given) and flags.epinephrine_delay_after_core_steps and (vitals.SpO2 < 92 or symptoms.wheeze >= 2 or symptoms.consciousness >= 1)",
        "effects": {
          "set_flags": {
            "airway_compromise": true,
            "airway_risk_increasing": true
          },
          "delta_symptoms": {
            "stridor": 1,
            "angioedema": 1
          },
          "delta_vitals": {
            "SpO2": -3,
            "RR": 2,
            "HR": 4,
            "SBP": -4
          }
        }
      },
      {
        "name": "airway_obstruction_triggered",
        "when": "flags.airway_compromise and (symptoms.stridor >= 2 or vitals.SpO2 < 88 or symptoms.consciousness >= 2)",
        "effects": {
          "set_flags": {
            "airway_obstruction_triggered": true,
            "advanced_support_indicated": true
          }
        }
      },
      {
        "name": "bvm_required_if_ventilation_failing",
        "when": "flags.airway_obstruction_triggered and (vitals.SpO2 < 88 or symptoms.consciousness >= 2 or vitals.RR < 10)",
        "effects": {
          "set_flags": {
            "bvm_required": true,
            "advanced_support_indicated": true
          }
        }
      },
      {
        "name": "oxygen_support_improves_spo2",
        "when": "flags.oxygen_on and (not flags.airway_obstruction_triggered) and vitals.SpO2 < 99",
        "effects": {
          "delta_vitals": {
            "SpO2": 2
          }
        }
      },
      {
        "name": "oxygen_limited_by_airway_obstruction",
        "when": "flags.oxygen_on and flags.airway_obstruction_triggered and vitals.SpO2 < 94",
        "effects": {
          "delta_vitals": {
            "SpO2": -1
          }
        }
      },
      {
        "name": "epi_primary_effect_ticks",
        "when": "flags.epi_effect_ticks > 0",
        "effects": {
          "delta_vitals": {
            "SBP": 7,
            "DBP": 4,
            "SpO2": 4,
            "HR": -8,
            "RR": -4
          },
          "delta_symptoms": {
            "wheeze": -1,
            "stridor": -1,
            "rash": -1,
            "angioedema": -1,
            "consciousness": -1
          },
          "counter_inc": {
            "epi_effect_ticks": -1
          }
        }
      },
      {
        "name": "fluid_support_ticks",
        "when": "flags.fluid_effect_ticks > 0",
        "effects": {
          "delta_vitals": {
            "SBP": 5,
            "DBP": 3,
            "HR": -2
          },
          "counter_inc": {
            "fluid_effect_ticks": -1
          }
        }
      },
      {
        "name": "bvm_effect_ticks",
        "when": "flags.bvm_effect_ticks > 0",
        "effects": {
          "delta_vitals": {
            "SpO2": 5,
            "RR": -1
          },
          "delta_symptoms": {
            "consciousness": -1
          },
          "counter_inc": {
            "bvm_effect_ticks": -1
          }
        }
      },
      {
        "name": "nebulized_epi_effect_ticks",
        "when": "flags.neb_epi_effect_ticks > 0",
        "effects": {
          "delta_symptoms": {
            "stridor": -1
          },
          "delta_vitals": {
            "SpO2": 1
          },
          "counter_inc": {
            "neb_epi_effect_ticks": -1
          }
        }
      },
      {
        "name": "bronchodilator_effect_ticks",
        "when": "flags.bronchodilator_effect_ticks > 0",
        "effects": {
          "delta_symptoms": {
            "wheeze": -1
          },
          "delta_vitals": {
            "SpO2": 1
          },
          "counter_inc": {
            "bronchodilator_effect_ticks": -1
          }
        }
      },
      {
        "name": "steroid_effect_record_ticks",
        "when": "flags.steroid_valid and flags.steroid_effect_ticks > 0",
        "effects": {
          "counter_inc": {
            "steroid_effect_ticks": -1
          }
        }
      },
      {
        "name": "asphyxia_death_after_prolonged_unresolved_delay",
        "when": "flags.epinephrine_delay_after_core_steps and (not flags.epi_im_given) and t >= 480 and (vitals.SpO2 < 78 or vitals.SBP < age_sbp_threshold or symptoms.consciousness >= 3)",
        "effects": {
          "set_flags": {
            "dead": true
          },
          "set_grade": 4,
          "set_vitals": {
            "SpO2": 50,
            "HR": 40,
