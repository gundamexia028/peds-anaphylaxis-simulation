  "end_conditions": {
    "success_when": "not flags.dead and flags.epi_im_given and flags.stopped_infusion and flags.oxygen_on and flags.help_called and flags.monitor_on and flags.bp_checked and flags.fluid_bolus_given and flags.first_reassessment_done and flags.second_reassessment_done and flags.family_communication and flags.sbar_handoff and grade <= 1 and vitals.SpO2 >= 95 and vitals.SBP >= age_sbp_threshold and t >= 300",
    "failure_when": "(flags.dead) or flags.epi_overdose_event",
    "max_time_seconds": 1200
  },
  "reporting": {
    "observe_recommendation": {
      "resp_distress_hours": "至少6–8小时",
      "circulatory_instability_hours": "至少12–24小时"
    }
  },
  "training": {
    "min_time_seconds_for_success": 300,
    "min_reassess_count_recommended": 2,
    "guided_prompts": [
      {
        "text": "步骤1：停用可疑药物，保留原静脉通路。",
        "reason": "本病例为输液过程中发生反应，关键是立即停止可疑药物暴露，同时保留抢救通路。",
        "done_when": "flags.stopped_infusion and flags.iv_access"
      },
      {
        "text": "步骤2：呼救并启动院内抢救支援。",
        "reason": "严重过敏反应进展快，需要医生、抢救车及团队协作同步到位。",
        "done_when": "flags.help_called"
      },
      {
        "text": "步骤3：快速ABC评估。",
        "reason": "判断气道、呼吸、循环和意识是否受累。",
        "done_when": "flags.abc_assessed or 'abc_assess' in action_first_time"
      },
      {
        "text": "步骤4：开放气道并给氧。",
        "reason": "气道/呼吸受累可迅速恶化，应尽早给氧并持续观察SpO₂和呼吸表现。",
        "done_when": "flags.oxygen_on"
      },
      {
        "text": "步骤5：体位管理。",
        "reason": "平卧、抬高下肢有助于改善回心血量；意识障碍或呕吐风险时头偏向一侧。",
        "done_when": "flags.positioned"
      },
      {
        "text": "步骤6：连接监护并测血压。",
        "reason": "心率、SpO₂、血压和末梢灌注是判断进展、补液和复评的依据。",
        "done_when": "flags.monitor_on and flags.bp_checked"
      },
      {
        "text": "步骤7：肌注肾上腺素。",
        "reason": "肌注肾上腺素是一线关键处置，不能被抗组胺药或糖皮质激素替代。",
        "done_when": "flags.epi_im_given"
      },
      {
        "text": "步骤8：输入晶体液快速补液量。",
        "reason": "循环受累时应按10–20 ml/kg进行容量复苏，单次最大500 ml；补液不能替代肾上腺素。",
        "done_when": "flags.fluid_bolus_given"
      },
      {
        "text": "步骤9：第一次复评。",
        "reason": "首次肌注肾上腺素后5–15 min复评呼吸、循环、意识、皮肤黏膜、SpO₂和血压，判断是否需要再次肌注或升级处理。",
        "done_when": "flags.first_reassessment_done"
      },
      {
        "text": "步骤10：根据复评处理持续咳嗽/喘息。",
        "reason": "若仍有咳嗽、喘息或支气管痉挛，可给予雾化支气管扩张剂；没有雾化处理时应继续记录呼吸症状。",
        "done_when": "flags.bronchodilator_neb or symptoms.wheeze == 0 or t >= 420"
      },
      {
        "text": "步骤11：第二次复评。",
        "reason": "告知家属前再次确认当前生命体征、咳喘改善、循环灌注和意识状态。",
        "done_when": "flags.second_reassessment_done"
      },
      {
        "text": "步骤12：告知家属并进行SBAR交接。",
        "reason": "稳定后交代诱因、时间轴、给药剂量/次数、补液量、生命体征变化、观察与转运重点。",
        "done_when": "flags.family_communication and flags.sbar_handoff"
      }
    ]
  },
  "scoring_notes": {
    "profile": "v1.2.4_infusion_double_reassessment",
    "total_score": 20,
    "principle": "输液中药物诱发严重过敏反应场景：立即停用可疑药物并保留抢救通路，呼救，ABC评估，给氧，体位，监护/血压，早期肌注肾上腺素，输入晶体液补液量，肌注后5–15 min第一次复评，根据复评处理残留咳喘，告知家属前第二次复评，随后家属沟通和SBAR交接。",
    "dose_rule": "本系统面向2–11岁儿童模拟病例，肌注肾上腺素按0.01 mg/kg计算，单次最大0.3 mg；低于目标剂量判定为无效，高于目标剂量判定为剂量不准确，超过0.3 mg判定为严重用药安全事件。",
    "planning_rule": "所有操作按钮均保持可选，避免因前台锁定影响受试者真实操作路径；训练模式下系统依据2025共识内置标准流程，显示当前推荐步骤及偏离提醒；考试模式不显示流程提示，仅记录操作路径与评分结果。",
    "fluid_rule": "快速补液需输入具体容量；合理范围为10–20 ml/kg，单次最大500 ml。低于10 ml/kg判定为循环支持不足，超过20 ml/kg或500 ml判定为补液不当/容量风险。"
  },
  "clinical_progression": {
    "1": {
      "stage": "I级｜早期皮肤黏膜/前驱期",
      "manifestations": "皮肤瘙痒、潮红、风团样皮疹，可伴手足/头皮瘙痒、烦躁或轻度咳嗽；生命体征可暂时稳定。"
    },
    "2": {
      "stage": "II级｜呼吸、胃肠或早期循环受累期",
      "manifestations": "咳嗽、胸闷、喘息、喉部发紧/声音改变，或腹痛、恶心、呕吐；可出现SpO₂下降或血压较基线下降。"
    },
    "3": {
      "stage": "III级｜严重呼吸受累/循环衰竭期",
      "manifestations": "喉鸣、发绀、明显低氧、低血压、末梢灌注差、嗜睡或反应差，提示休克或重要器官灌注不足。"
    },
    "4": {
      "stage": "IV级｜心跳或呼吸骤停期",
      "manifestations": "呼吸骤停或心跳骤停，意识丧失，需立即就地心肺复苏并启动高级生命支持。"
    }
  },
  "clinical_manifestation_display": {
    "principle": "当前临床表现不再仅显示固定标签，而是根据症状、生命体征、监护/血压可见性和治疗反应，按皮肤黏膜、呼吸/气道、胃肠、循环、神经/意识五个系统动态生成。",
    "basis": "2025严重过敏反应共识关于临床表现和病程进展的描述。"
